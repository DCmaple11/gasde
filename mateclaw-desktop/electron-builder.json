{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "vip.mate.openclawmax",
  "productName": "OpenClawMax",
  "copyright": "Copyright © OpenClawMax",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist-electron/**/*",
    "package.json",
    "!**/*.map"
  ],
  "extraResources": [
    {
      "from": "resources/app.jar",
      "to": "app/app.jar",
      "filter": ["**/*"]
    },
    {
      "from": "resources/jre",
      "to": "jre",
      "filter": ["**/*"]
    },
    {
      "from": "build/tray.ico",
      "to": "tray/tray.ico",
      "filter": ["**/*"]
    },
    {
      "from": "build/tray.png",
      "to": "tray/tray.png",
      "filter": ["**/*"]
    },
    {
      "from": "build/icon.png",
      "to": "tray/icon.png",
      "filter": ["**/*"]
    }
  ],
  "asar": true,
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "OpenClawMax"
  },
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["arm64"] },
      { "target": "zip", "arch": ["arm64"] }
    ],
    "icon": "build/icon.png",
    "identity": null,
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "dmg": {
    "sign": false
  },
  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] }
    ],
    "icon": "build/icon.png",
    "category": "Office"
  }
}
