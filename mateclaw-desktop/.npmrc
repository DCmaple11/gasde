# npm 镜像源（npm 官方支持的配置项）
registry=https://registry.npmmirror.com/

# 注意：electron 二进制镜像（electron_mirror / electron_builder_binaries_mirror）
# 不是 npm 配置项，写在 .npmrc 会触发 "Unknown project config" 警告。
# 但 npm 会把 .npmrc 的键注入为 npm_config_<key> 环境变量传给 install 子进程，
# electron postinstall 正是读这个变量来走镜像 —— 所以功能正常，警告可忽略。
#
# 若想消除警告，删除下面两行，改为安装时临时设环境变量：
#   $env:electron_mirror="https://npmmirror.com/mirrors/electron/"; npm install
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
